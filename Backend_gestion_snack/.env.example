# =============================================================
#  Backend — Template des variables d'environnement
#  Copier ce fichier en .env et renseigner les vraies valeurs
# =============================================================

# ─── Base de données ──────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://<host>/<dbname>?sslmode=require&channel_binding=require&stringtype=unspecified
DATABASE_USERNAME=your_db_username
DATABASE_PASSWORD=your_db_password

# ─── URL publique du backend ──────────────────────────────────
APP_BASE_URL=https://your-service.onrender.com

# ─── CORS ─────────────────────────────────────────────────────
# Plusieurs origines séparées par une virgule :
# ALLOWED_ORIGINS=https://app1.vercel.app,https://app2.vercel.app
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ─── Port ─────────────────────────────────────────────────────
PORT=8080
