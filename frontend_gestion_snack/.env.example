# ============================================================
# Variables d'environnement - Frontend Gestion Snack
# Copier ce fichier en .env et renseigner les valeurs
# ============================================================

# URL de l'API backend
# - Local:      http://localhost:8080/api
# - Production: https://<nom-service>.onrender.com/api
VITE_API_BASE_URL=http://localhost:8080/api

# Clé API Groq (chatbot)
VITE_GROQ_API_KEY=your_groq_api_key_here

# Clé API ElevenLabs (TTS chat vocal live)
# https://elevenlabs.io → Profile → API Key
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
